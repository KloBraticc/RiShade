<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Rishade.Views.MainWindow"
        xmlns:local="clr-namespace:Rishade.Converters"
        xmlns:vm="clr-namespace:Rishade.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        Title="Rishade Setup"
        Width="500"
        Height="360"
        MinWidth="500"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <local:IconSVGConverter x:Key="IconSVGConverter"/>
    </Window.Resources>

    <Grid>
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource AppBg}" Offset="0.1"/>
                    <GradientStop Color="{StaticResource PanelBg}" Offset="0.3"/>
                    <GradientStop Color="{StaticResource PanelBg2}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid ColumnDefinitions="48,*" RowDefinitions="*,Auto">
            <Border Classes="sidebar"
                    Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="2">
                <Grid RowDefinitions="Auto,*">

                    <Grid Grid.Row="1">
                        <ScrollViewer>
                            <ListBox Name="NavList"
                                     Classes="nav"
                                     Margin="10,0,0,0"
                                     SelectionChanged="NavList_SelectionChanged">

                                <ListBoxItem Tag="Home">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ContentControl Width="16" Height="16"
                                            Content="{Binding Source=Home, Converter={StaticResource IconSVGConverter}}"/>
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>
                        </ScrollViewer>

                        <Border Name="NavIndicator"
                                Width="6"
                                CornerRadius="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="0"
                                Opacity="1"
                                IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Grid.Row="0" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="1">
                    <ContentControl x:Name="MainContent"/>
                </ScrollViewer>
            </Grid>
<Border Grid.Column="0"
        Grid.ColumnSpan="2"
        Grid.Row="1"
        Height="50"
        Background="{StaticResource PanelBg2}"
        BorderBrush="#FF444444"
        BorderThickness="1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Spacing="10">
            <TextBlock Text="Discord"
                       FontSize="14"
                       Foreground="LightBlue"
                       Cursor="Hand"
                       PointerPressed="Disc_Click"/>
            <TextBlock Text="GitHub"
                       FontSize="14"
                       Foreground="LightBlue"
                       Cursor="Hand"
                       PointerPressed="GitHub_Click"/>
        </StackPanel>

        <Button Grid.Column="4"
                Height="34"
                FontSize="14"
                Margin="6,0,20,0"
                Content="Close"
                Classes="corner4"
                Click="Closebutton"/>
    </Grid>
</Border>
        </Grid>
    </Grid>
</Window>